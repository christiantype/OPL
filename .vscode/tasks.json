{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Publish",
      "type": "shell",
      "command": "git add -A && git commit -m '${input:commitMessage}' && git push",
      "group": {
        "kind": "build",
        "isDefault": true
      },
      "presentation": {
        "reveal": "always",
        "panel": "shared"
      }
    }
  ],
  "inputs": [
    {
      "id": "commitMessage",
      "type": "promptString",
      "description": "What did you change?",
      "default": "Update site"
    }
  ]
}
